{
  "name": "string-instrument",
  "version": "0.0.11",
  "description": "A little library for working with strings",
  "keywords": [
    "string",
    "strings",
    "slug",
    "camelcase",
    "pascalcase",
    "titlecase",
    "kebabcase",
    "hyphen separated",
    "underscore separated",
    "ordinal"
  ],
  "homepage": "https://chrisalley.github.io/string-instrument/",
  "license": "MIT",
  "author": "Chris Alley",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisalley/string-instrument"
  },
  "exports": [
    "./dist/string-instrument.js"
  ],
  "source": "src/index.ts",
  "files": [
    "dist/string-instrument.js"
  ],
  "engineStrict": true,
  "engines": {
    "node": ">=24.14"
  },
  "packageManager": "pnpm@10.33.0+sha256.bfcc1bcbad279b13a516c446a75b3c58b6904b45d57a1951411015e50b751a80",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "coverage": "vitest run --coverage",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "types": "tsc",
    "typedoc": "pnpx typedoc src/index.ts",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
