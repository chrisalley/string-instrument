{
  "name": "string-instrument",
  "version": "0.0.12",
  "description": "A little library for working with strings",
  "keywords": [
    "string",
    "strings",
    "slug",
    "camelcase",
    "pascalcase",
    "titlecase",
    "kebabcase",
    "hyphen separated",
    "underscore separated",
    "ordinal"
  ],
  "homepage": "https://chrisalley.github.io/string-instrument/",
  "license": "MIT",
  "author": "Chris Alley",
  "type": "module",
  "types": "./dist/string-instrument.d.ts",
  "module": "./dist/string-instrument.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisalley/string-instrument"
  },
  "exports": {
    "types": "./dist/string-instrument.d.ts",
    "import": "./dist/string-instrument.js"
  },
  "source": "src/index.ts",
  "files": [
    "dist/*"
  ],
  "engineStrict": true,
  "engines": {
    "node": ">=24.14"
  },
  "packageManager": "pnpm@10.33.0+sha256.bfcc1bcbad279b13a516c446a75b3c58b6904b45d57a1951411015e50b751a80",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "coverage": "vitest run --coverage",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "types": "tsc",
    "typedoc": "pnpx typedoc src/index.ts",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "overrides": {
      "@microsoft/api-extractor>lodash": ">=4.18.1"
    }
  }
}
