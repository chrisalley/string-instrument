{
  "name": "string-instrument",
  "version": "0.0.14",
  "description": "A little library for working with strings",
  "keywords": [
    "string",
    "strings",
    "slug",
    "camelcase",
    "pascalcase",
    "titlecase",
    "kebabcase",
    "hyphen separated",
    "underscore separated",
    "ordinal"
  ],
  "homepage": "https://chrisalley.github.io/string-instrument/",
  "license": "MIT",
  "author": "Chris Alley",
  "type": "module",
  "types": "./dist/string-instrument.d.ts",
  "module": "./dist/string-instrument.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisalley/string-instrument"
  },
  "exports": {
    "types": "./dist/string-instrument.d.ts",
    "import": "./dist/string-instrument.js"
  },
  "source": "src/index.ts",
  "files": ["dist/*"],
  "engineStrict": true,
  "engines": {
    "node": ">=24.14"
  },
  "packageManager": "pnpm@10.33.0+sha256.bfcc1bcbad279b13a516c446a75b3c58b6904b45d57a1951411015e50b751a80",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "coverage": "vitest run --coverage",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "format": "pnpx @biomejs/biome format",
    "format:write": "pnpx @biomejs/biome format --write",
    "lint": "pnpx @biomejs/biome lint",
    "lint:write": "pnpx @biomejs/biome lint --write",
    "check": "pnpx @biomejs/biome check",
    "check:write": "pnpx @biomejs/biome check --write",
    "types": "tsc",
    "typedoc": "pnpx typedoc src/index.ts",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "changelog": "pnpx conventional-changelog -r 0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@microsoft/api-extractor": "^7.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "conventional-changelog": "^7.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "unplugin-dts": "1.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "overrides": {
      "@microsoft/api-extractor>lodash": ">=4.18.1"
    }
  }
}
